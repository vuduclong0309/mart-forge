# GME Options Mart — local environment variables
# Copy to .env and fill in values. Never commit .env itself.
# Usage:  set -a; source .env; set +a

# --- Data mode ---
# Set to "false" for live CBOE delayed quotes; "true" for offline fixture demo.
# GME_USE_FIXTURE=true

# --- dbt target ---
# "dev" = local DuckDB (default), "motherduck" = shared MotherDuck warehouse.
# DBT_TARGET=dev

# --- MotherDuck (optional) ---
# MOTHERDUCK_TOKEN=
# GME_MOTHERDUCK_PATH=md:gme_options

# --- Dashboard warehouse path ---
# Override the DuckDB file the dashboard reads.
# Local default: target/gme_options.duckdb
# For MotherDuck: md:gme_options
# GME_DASHBOARD_DB_PATH=
